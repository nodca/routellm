[Unit]
Description=metapi-rs lightweight LLM router
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=routellm
Group=routellm
WorkingDirectory=/opt/routellm
EnvironmentFile=/etc/routellm.env
ExecStart=/opt/routellm/metapi-rs
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
